urse:"course-ggb.html",grade:"國中 / 高中",topic:"國際體系"},{file:"need-learning-path.html",short:"人才培育",title:"人才培育計畫 / 長線規劃",intro:"把升學、競賽、課程與能力養成拉成完整路徑。",points:["先看長線目標。","再配置課程與競賽。","最後才是每一年該做什麼。"],relatedCourse:"course-amc-aime.html",grade:"跨學段",topic:"長線規劃"}];
  const COURSES=[{file:"course-p.html",title:"小學數學 P",level:"國小",theme:"gold",summary:"從數感、應用題到競賽入門，建立穩定的數學表達。",bullets:["數感與應用題","私中與拔尖基礎","競賽啟蒙"],tags:["國小","P","私中"]},{file:"course-j.html",title:"國中數學 J",level:"國中",theme:"navy",summary:"兼顧校內、資優與後續高中數理銜接。",bullets:["代數與幾何深化","穩定超前","資優題型訓練"],tags:["國中","J","資優"]},{file:"course-fa00.html",title:"FA00 科學班 / 數資班備考",level:"國中",theme:"navy",summary:"針對科學班與數資班甄選常見題型與複試需求設計。",bullets:["高鑑別題型","複試策略","短衝規劃"],tags:["FA00","科學班","數資班"]},{file:"course-s.html",title:"高中數學 S",level:"高中",theme:"navy",summary:"建立更高階的抽象推理與解題結構。",bullets:["高階代數","函數與論證","學測難題"],tags:["高中","S","學測"]},{file:"course-ggb.html",title:"GGB 幾何探究",level:"國中 / 高中",theme:"gold",summary:"用動態幾何建立觀察、猜想與證明能力。",bullets:["動態觀察","猜想驗證","證明前訓練"],tags:["GGB","幾何","探究"]},{file:"course-science-camp.html",title:"科學班前瞻營",level:"國中",theme:"gold",summary:"以主題式探究與實作作為科學班前期暖身。",bullets:["主題探究","跨科整合","前瞻營"],tags:["營隊","科學班","探究"]},{file:"course-amc-aime.html",title:"FA 高階競賽",level:"國中 / 高中",theme:"navy",summary:"銜接 AMC / AIME 與更高階競賽需求。",bullets:["AMC / AIME","高階數論","長線競賽布局"],tags:["FA","AMC","AIME"]}];
  const ARTICLES=[{slug:"gifted-path",title:"如何為孩子規劃一條不焦慮的資優路徑",date:"2026-03-10",category:"教學觀點",tags:["學習規劃","資優","家長決策"],keywords:["資優規劃","升學路線","家長焦慮"],summary:"很多家長不是不努力，而是資訊太多，最後每個方向都想抓。真正需要的是先把目標、時間與程度排清楚。",cover:"金色路徑圖",popularity:92,freshness:98,body:["先定義近期目標、中期布局與長期能力，再倒推現在要補什麼。","私中、國中數資與高中科學班，準備重點本來就不同。","把所有路都抓住，不等於比較完整。"]},{slug:"private-school",title:"準備私中，不只是把難題做完",date:"2026-02-28",category:"升學策略",tags:["私中","國小","數學"],keywords:["私中考試","私校入學","速度"],summary:"私中準備的核心不是單題難度，而是穩定度、完成率與題型辨識力。",cover:"深藍題本",popularity:87,freshness:84,body:["問題常常不在程度，而在整體作答節奏沒有被訓練。","真正要問的不是他會不會這一題，而是能不能穩定完成一份卷子。"]},{slug:"when-to-start-amc",title:"AMC 應該什麼時候開始？",date:"2026-02-16",category:"競賽規劃",tags:["AMC","競賽","國中","高中"],keywords:["AMC","AIME","開始時間"],summary:"AMC 不是越早開始越好，而是基礎、抽象能力與持續訓練習慣都準備好時效果才會真正出來。",cover:"競賽節奏",popularity:95,freshness:78,body:["關鍵不是年級，而是承接能力。","對還在補基本觀念的孩子來說，過早投入常常只會得到挫折。"]},{slug:"science-class-family",title:"想走科學班，家長應該提前準備什麼？",date:"2026-01-15",category:"升學策略",tags:["科學班","國中","家長"],keywords:["科學班","準備","家長"],summary:"真正該提早準備的是能力結構與學習節奏。",cover:"科學探究",popularity:88,freshness:68,body:["數學與自然理解、實驗敏感度、問題整理能力，都是長期累積。","如果要走這條路，建議盡早把課程、探究、競賽與考試策略串在一起。"]}];
  const MOMS=[{slug:"win-everything",title:"你不需要把每一條路都替孩子贏下來",date:"2026-03-08",category:"放下過度焦慮",tags:["情緒支持","家長壓力"],keywords:["焦慮","媽媽","陪伴"],summary:"真正能陪孩子走得遠的，不是每一步都替他清空風險，而是讓他知道有人穩穩陪著。",cover:"溫柔金粉",popularity:96,freshness:96,body:["教育從來不是單次勝負，而是很多段起伏的長跑。","你不需要把每一條路都替孩子贏下來，只需要陪他把真正重要的那幾步走穩。"]},{slug:"slow-down",title:"在做決定之前，先讓自己慢下來",date:"2026-02-24",category:"讓心安定",tags:["決策","媽媽"],keywords:["慢下來","決定","焦慮"],summary:"當你很急的時候，通常不是最適合做重大教育決定的時候。",cover:"靜心粉霧",popularity:83,freshness:87,body:["很多好決定，都不是在最焦慮的那一刻做出來的。","先停一下、先整理、先看清楚你們家庭真正的目標，再做選擇。"]},{slug:"child-not-project",title:"孩子不是一個待完成的專案",date:"2026-01-18",category:"陪伴提醒",tags:["親子","陪伴"],keywords:["孩子","專案","陪伴"],summary:"當我們太用力管理孩子，很容易忘記他其實是一個正在長成自己的生命。",cover:"暖心漫畫",popularity:90,freshness:74,body:["規劃很重要，但不要讓孩子只剩下被安排。","真正長久的教育，不只是把孩子推高，而是讓他在成長裡沒有失去自己。"]}];
