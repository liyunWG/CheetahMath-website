  function page(route){const main=document.querySelector("main.page");if(main)main.innerHTML=route;}
  function applyChrome(title,subtitle){document.title=title;document.querySelectorAll(".brand__title").forEach((el)=>el.innerHTML=`<img src="pic/logo.png" alt="獵豹科教 logo">`);document.querySelectorAll(".brand__subtitle").forEach((el)=>el.textContent=subtitle||SITE.subtitle);document.querySelectorAll(".nav").forEach((nav)=>nav.innerHTML=NAV.map(([href,label])=>`<a class="${href===PAGE()?"is-active":""}" href="${href}">${label}</a>`).join(""));document.querySelectorAll(".footer__inner").forEach((footer)=>footer.innerHTML=`<div class="footer-grid"><div><h3>${SITE.brand}</h3><p>${SITE.footer}</p></div><div><h3>快速入口</h3><div class="footer-links"><a href="one-page.html">一頁認識獵豹</a><a href="needs.html">家長導航</a><a href="search.html">全站搜尋</a></div></div><div><h3>社群與客服</h3><div class="footer-social"><a class="footer-social__link footer-social__link--line" href="${SITE.lineUrl}" target="_blank" rel="noreferrer"><img src="pic/line_icon.png" alt="官方 Line"><span>一對一專業教育諮詢</span></a><a class="footer-social__link" href="${SITE.fbUrl}" target="_blank" rel="noreferrer"><img src="pic/FB_icon.png" alt="Facebook"><span>Facebook 社團</span></a><a class="footer-social__link" href="${SITE.ytUrl}" target="_blank" rel="noreferrer"><img src="pic/YT_icon.png" alt="YouTube"><span>YouTube 頻道</span></a></div></div></div>`);document.querySelectorAll(".social-float").forEach((el)=>el.innerHTML=`<a class="social-float__link social-float__link--line" href="${SITE.lineUrl}" target="_blank" rel="noreferrer"><span class="social-float__badge">一對一專業<br>教育諮詢</span><img src="pic/line_icon.png" alt="官方 Line"></a><a class="social-float__link" href="${SITE.fbUrl}" target="_blank" rel="noreferrer"><img src="pic/FB_icon.png" alt="Facebook"></a><a class="social-float__link" href="${SITE.ytUrl}" target="_blank" rel="noreferrer"><img src="pic/YT_icon.png" alt="YouTube"></a>`);setupMobileNav();}
  function setupMobileNav(){document.querySelectorAll(".topbar__inner").forEach((shell)=>{const nav=shell.querySelector(".nav");if(!nav)return;let button=shell.querySelector(".topbar__nav-toggle");if(!button){button=document.createElement("button");button.type="button";button.className="topbar__nav-toggle";button.setAttribute("aria-expanded","false");button.setAttribute("aria-label","Open menu");button.innerHTML='<span class="topbar__nav-toggle-bar"></span>';shell.insertBefore(button,nav);}if(button.__mobileNavReady)return;button.__mobileNavReady=true;button.removeAttribute("data-mobile-nav-ready");const isDesktop=()=>window.innerWidth>=980;const toggleEvent="PointerEvent"in window?"pointerup":"click";const setOpen=(open)=>{button.setAttribute("aria-expanded",String(open));button.setAttribute("aria-label",open?"Close menu":"Open menu");nav.classList.toggle("is-open",open);shell.classList.toggle("is-nav-open",open);};const closeMenu=()=>setOpen(false);const toggleMenu=(event)=>{if(event){event.preventDefault();event.stopPropagation();}if(isDesktop())return;setOpen(button.getAttribute("aria-expanded")!=="true");};button.addEventListener(toggleEvent,toggleMenu,{passive:false});nav.addEventListener("click",(event)=>event.stopPropagation());nav.querySelectorAll("a").forEach((link)=>{link.addEventListener("click",()=>closeMenu());});document.addEventListener("click",(event)=>{if(isDesktop())return;if(!shell.contains(event.target))closeMenu();});window.addEventListener("resize",()=>{if(isDesktop())closeMenu();},{passive:true});});}
function buildHome(){return `<section class="hero hero--banner-only"><div class="container"><div class="hero-panel hero-panel--banner" data-banner-slider>${BANNERS.map((banner,index)=>`<div class="hero-banner${index===0?" is-active":""}"><img src="${banner.src}" alt="${banner.alt}"></div>`).join("")}<div class="hero-banner__dots">${BANNERS.map((_,index)=>`<button type="button" class="hero-banner__dot${index===0?" is-active":""}" data-banner-dot="${index}" aria-label="切換到第 ${index+1} 張 banner"></button>`).join("")}</div></div><div class="goal-chip-row">${GOALS.map((g,i)=>`<a class="goal-chip reveal-seq" style="--delay:${i*60}ms" href="${g.file}"><span>${g.short}</span><small>${g.title}</small></a>`).join("")}</div></div></section>${section("一頁認識獵豹","給完全陌生的家長快速理解品牌、理念與教學方式。",`<div class="feature-slab"><div><span class="eyebrow">Landing Page</span><h3>60 秒看懂：獵豹教什麼、適合誰、和一般補習班差在哪裡。</h3><p>先建立信任，再導向家長導航、課程或諮詢。</p></div><div class="page-nav"><a class="button button--primary" href="one-page.html">前往一頁認識獵豹</a><a class="button button--secondary" href="about.html">看品牌理念</a></div></div>`)}${section("精選文章","首頁固定可自訂三篇，優先放最能建立信任與專業度的內容。",`<div class="grid grid--3">${ARTICLES.slice(0,3).map((a)=>card(a,articleUrl(a.slug),"navy")).join("")}</div>`)}${section("全站搜尋","原本好用的搜尋入口已補回首頁，可直接找私中、AMC、科學班、EGMO 或榜單文章。",`<div class="feature-slab"><form action="search.html" class="search-quick-form"><label class="search-label" for="home-search-input">搜尋關鍵字</label><input id="home-search-input" class="search-input" type="search" name="q" placeholder="例如：私中、AMC、科學班、EGMO、榜單"><div class="tag-row"><span class="tag">私中</span><span class="tag">科學班</span><span class="tag">AMC</span><span class="tag">EGMO</span><span class="tag">榜單</span></div><div class="page-nav"><button class="button button--primary" type="submit">開始搜尋</button><a class="button button--secondary" href="search.html">前往完整搜尋頁</a></div></form></div>`)}${section("最新消息","活動訊息、開課公告與站務更新分開呈現，不和深度文章混在一起。",`<div class="grid grid--3">${NEWS.map((n)=>card(n,"news.html","gold")).join("")}</div>`)}${section("獵豹菁英","這一區專門用來放榜單與錄取成果，後續可依年度、類型與學校分組。",`<div class="grid grid--3">${STUDENT_HONORS.map((item)=>`<article class="card"><h3>${item.title}</h3><p>${item.text}</p>${tags(item.tags)}</article>`).join("")}</div>`)}${section("星媽的正能量","用圖文、短句與分類，提供讓家長喘一口氣的內容區。",`<div class="grid grid--3">${MOMS.map((m)=>card(m,momUrl(m.slug),"pink",true)).join("")}</div>`,"section--mom")}${section("快速進入學習系統","把測評系統、作業、補課影片與家長提醒整理成一個清楚入口。",`<div class="split-panel"><div class="split-panel__main"><h3>學習系統入口頁</h3><p>學生可以從這裡進入測評系統、查找作業、看補課影片，也能在家長端看到提醒與操作說明。</p><div class="page-nav"><a class="button button--primary" href="learning-system.html">前往學習系統</a><a class="button button--secondary" href="${SITE.systemUrl}" target="_blank" rel="noreferrer">直接開啟系統</a></div></div><div class="split-panel__side"><div class="system-tile">作業入口</div><div class="system-tile system-tile--navy">補課影片</div><div class="system-tile">家長提醒</div></div></div>`)}`;}
  function buildListPage(name,body){return `<section class="page-hero"><div class="container"><span class="eyebrow">${name}</span><h1>${body.title}</h1><p>${body.intro}</p>${body.nav||""}</div></section>${body.sections.join("")}`;}
  function buildSearch(){return `<section class="page-hero"><div class="container"><span class="eyebrow">全站搜尋</span><h1>站內可搜尋、每篇文章可加標籤，搜尋時標籤優先、內文其次。</h1><p>搜尋結果同時涵蓋文章、文章專欄、課程、家長導航、最新消息、星媽正能量與獵豹菁英。</p></div></section><section class="section"><div class="container search-layout"><aside class="search-panel"><label class="search-label" for="site-search-input">搜尋關鍵字</label><input id="site-search-input" class="search-input" type="search" placeholder="例如：私中、AMC、科學班、EGMO、榜單" value="${PARAMS().get("q")||""}"><div class="filter-group"><span>內容類型</span><select id="filter-type"><option value="">全部</option><option value="文章">文章</option><option value="文章專欄">文章專欄</option><option value="課程">課程</option><option value="家長導航">家長導航</option><option value="星媽正能量">星媽正能量</option><option value="最新消息">最新消息</option><option value="獵豹菁英">獵豹菁英</option></select></div><div class="filter-group"><span>年級 / 區塊</span><select id="filter-grade"><option value="">全部</option><option value="國小">國小</option><option value="國中">國中</option><option value="高中">高中</option><option value="跨學段">跨學段</option><option value="家長">家長</option><option value="文章專欄">文章專欄</option><option value="獵豹菁英">獵豹菁英</option></select></div><div class="filter-group"><span>排序</span><select id="filter-sort"><option value="best">最佳結果</option><option value="latest">最新</option><option value="popular">最熱門</option></select></div></aside><div><div id="search-results" class="search-results"></div></div></div></section><script type="application/json" id="search-data">${JSON.stringify(searchData())}</script>`;}
  const articlePage=(a)=>`<section class="page-hero"><div class="container article-layout"><div class="article-main">${cover(a.cover,"navy")}<div class="article-head"><span class="eyebrow">${a.category}</span><h1>${a.title}</h1>${meta(a.date,a.category)}${tags(a.tags)}<p class="article-summary">${a.summary}</p></div><div class="article-body">${a.body.map((p)=>`<p>${p}</p>`).join("")}</div><div class="page-nav"><a class="back-link" href="columns.html">回文章專欄</a><a class="back-link" href="index.html">回首頁</a></div></div><aside class="article-side"><div class="card"><h3>文章資訊</h3><p><strong>slug：</strong>${a.slug}</p><p><strong>關鍵字：</strong>${a.keywords.join("、")}</p></div></aside></div></section>`;
  const momPage=(a)=>`<section class="page-hero page-hero--mom"><div class="container article-layout"><div class="article-main">${cover(a.cover,"pink")}<div class="article-head"><span class="eyebrow">星媽的正能量</span><h1>${a.title}</h1>${meta(a.date,a.category,true)}${tags(a.tags,true)}<p class="article-summary">${a.summary}</p></div><div class="article-body">${a.body.map((p)=>`<p>${p}</p>`).join("")}</div><div class="page-nav"><a class="back-link" href="star-mom.html">回星媽分類頁</a><a class="back-link" href="index.html">回首頁</a></div></div><aside class="article-side"><div class="card card--mom"><h3>這篇的分類</h3><p>${a.category}</p><p><strong>關鍵字：</strong>${a.keywords.join("、")}</p></div></aside></div></section>`;
  const routes={"index.html":()=>["獵豹科教｜數理資優長線布局","數理資優學習系統",buildHome()],"one-page.html":()=>["一頁認識獵豹｜獵豹科教","一頁認識獵豹",buildListPage("一頁認識獵豹",{title:"先看懂獵豹的理念、教法與適合的家庭，再決定要不要更深入。",intro:"這一頁是獵豹對外的第一張名片。給從廣告、社群或朋友轉介進來的家長，一個快速、完整、可信任的第一印象。",nav:`<div class="page-nav"><a class="button button--primary" href="contact.html">預約諮詢</a><a class="button button--secondary" href="needs.html">從家長目標開始</a></div>`,sections:[section("獵豹的核心理念","我們不把孩子當作待修補的問題，而是把學習看成一條要被設計好的路。",`<div class="grid grid--3"><article class="card"><h3>先看懂孩子現在在哪裡</h3><p>能力診斷不是貼標籤，而是為了知道接下來應該往哪裡推。</p></article><article class="card"><h3>再安排真正適合的節奏</h3><p>超前不一定代表有效，合適的進度、深度與回饋才有長期價值。</p></article><article class="card"><h3>最後把成長做成可追蹤的系統</h3><p>家長不該只能靠感覺判斷孩子有沒有進步。</p></article></div>`)]})],"needs.html":()=>["家長導航｜獵豹科教","家長導航",buildListPage("家長導航",{title:"很多家長不是想逛網站，而是想解決眼前很具體的問題。",intro:"先從目標開始，再回頭看課程與文章，會比從課程分類硬找容易很多。",sections:[section("按目標找內容","首頁的金色快捷按鈕，也會從這裡延伸到更完整的說明頁。",`<div class="goal-grid">${GOALS.map((g)=>`<a class="feature-box feature-box--goal" href="${g.file}"><strong>${g.title}</strong><p>${g.intro}</p><span class="card-link">看完整說明</span></a>`).join("")}</div>`)]})],"courses.html":()=>["課程總覽｜獵豹科教","課程總覽",buildListPage("課程總覽",{title:"課程不是平鋪直敘地從淺到深，而是對應不同階段、目標與能力結構。",intro:"新網站的課程分類依照你指定的最新架構整理，已移除 Sci 與 Scratch。",nav:`<div class="page-nav"><a class="button button--primary" href="contact.html">預約選課諮詢</a><a class="button button--secondary" href="learning-system.html">看學習系統</a></div>`,sections:[section("課程分類","每門課都先讓家長看懂定位、適合對象與延伸方向。",`<div class="grid grid--3">${COURSES.map((c)=>`<article class="card">${cover(c.title,c.theme)}${meta("",c.level)}<h3>${c.title}</h3><p>${c.summary}</p><ul class="list">${c.bullets.map((b)=>`<li>${b}</li>`).join("")}</ul><a class="card-link" href="${c.file}">進入課程頁</a></article>`).join("")}</div>`)]})],"columns.html":()=>["文章專欄｜獵豹科教","文章專欄",""],"star-mom.html":()=>["星媽的正能量｜獵豹科教","星媽的正能量",`<section class="page-hero page-hero--mom"><div class="container"><span class="eyebrow">星媽的正能量</span><h1>不是給方法而已，也給家長一點喘息、一點被理解的空間。</h1><p>這區以圖文短篇為主，未來可擴充成更多篇文章、漫畫圖文與分類標籤。</p>${tags(["放下過度焦慮","讓心安定","陪伴提醒"],true)}</div></section>${section("正能量圖文","先把分類感做出來，之後每篇都可以帶一張圖或一組漫畫圖。",`<div class="grid grid--3">${MOMS.map((a)=>card(a,momUrl(a.slug),"pink",true)).join("")}</div>`,"section--mom")}`],"news.html":()=>["最新消息｜獵豹科教","最新消息",buildListPage("最新消息",{title:"首頁可放精選消息，這裡則保留完整的活動與公告列表。",intro:"活動訊息、說明會、開班公告與站務更新，應該和深度文章分流。",sections:[section("消息列表","之後可以再加月份、標籤與報名連結。",`<div class="grid grid--3">${NEWS.map((n)=>card(n,"","gold")).join("")}</div>`)]})],"learning-system.html":()=>["學習系統｜獵豹科教","學習系統",buildListPage("學習系統",{title:"把測評系統、作業、補課影片與家長提醒，整理成一個清楚入口。",intro:"這一頁可直接作為學生與家長的入口頁，避免每次都得從聊天記錄回找系統網址。",nav:`<div class="page-nav"><a class="button button--primary" href="${SITE.systemUrl}" target="_blank" rel="noreferrer">進入測評系統</a><a class="back-link" href="index.html">回首頁</a></div>`,sections:[section("學習系統架構","除了登入按鈕，也要讓家長知道這頁還能做什麼。",`<div class="grid grid--3"><article class="card"><h3>學生入口</h3><p>登入後進入作業、補課影片與學習紀錄。</p></article><article class="card"><h3>家長入口</h3><p>看提醒、補課規則與系統操作說明。</p></article><article class="card"><h3>客服導流</h3><p>若系統登入或操作有問題，可直接連到官方 Line。</p></article></div>`)]})],"about.html":()=>["關於獵豹｜獵豹科教","關於獵豹",buildListPage("關於獵豹",{title:"獵豹不是單純的補習班形象，而是用數理專長幫家庭建立更清楚判斷的一個教育品牌。",intro:"關於我們不只是品牌介紹，也要說清楚理念、教學方法與為什麼值得信任。",sections:[section("品牌重點","這裡建議保留品牌、師資理念、教學系統與長線培養觀。",`<div class="grid grid--3"><article class="card"><h3>理念清楚</h3><p>先讓家長理解我們怎麼看孩子的學習，再看課程安排。</p></article><article class="card"><h3>系統化教學</h3><p>不是只講上課內容，也重視診斷、追蹤與回饋。</p></article><article class="card"><h3>長線布局</h3><p>從國小到高中，課程與目標之間需要能銜接。</p></article></div>`)]})],"features.html":()=>["核心特色｜獵豹科教","核心特色",buildListPage("核心特色",{title:"網站應該清楚告訴家長：獵豹的特色不是只在難度，而是在系統與判斷力。",intro:"這區可對應現站的獵豹特色，但新版要更聚焦在家長真的在意的差異點。",sections:[section("四個核心差異","這些是家長看完後應該能記住的品牌印象。",`<div class="grid grid--2"><article class="card"><h3>從目標倒推，而不是先推課</h3><p>先判斷目標與孩子狀態，才知道該學什麼。</p></article><article class="card"><h3>不是只有補內容，還補解題系統</h3><p>很多孩子卡住不是不會，而是方法與表達沒有建立起來。</p></article><article class="card"><h3>家長看得懂進度與風險</h3><p>減少資訊不對稱帶來的焦慮與誤判。</p></article><article class="card"><h3>從短期考試延伸到長線人才培養</h3><p>這會讓課程選擇與內容設計更有一致性。</p></article></div>`)]})],"students.html":()=>["獵豹菁英｜獵豹科教","獵豹菁英",buildListPage("獵豹菁英",{title:"這一區專門整理榜單、錄取成果、競賽捷報與學生學習故事。",intro:"除了列出成果，也會逐步把榜單依年度、目標與學校分組，讓家長能快速找到自己在意的升學或競賽結果。",sections:[section("榜單與成果方向","先用三種家長最常查找的成果分類作為入口。",`<div class="grid grid--3">${STUDENT_HONORS.map((item)=>`<article class="card"><h3>${item.title}</h3><p>${item.text}</p>${tags(item.tags)}</article>`).join("")}</div>`),section("後續可加的數據觀測","除了榜單，也建議把年度成果文章、熱門捷報與重要錄取案例整理成可搜尋資料。",`<div class="grid grid--3"><article class="card"><h3>年度錄取榜單</h3><p>依私中、國中數資、高中科學班、高中數資分開整理。</p></article><article class="card"><h3>競賽與檢定捷報</h3><p>把 AMC、AIME、APX、EGMO 等成果統一歸檔。</p></article><article class="card"><h3>學生故事與心得</h3><p>將心得分享和錄取故事一起保留，讓成果更有說服力。</p></article></div>`)]})],"contact.html":()=>["聯絡我們｜獵豹科教","聯絡我們",buildListPage("聯絡我們",{title:"在聯絡之前，先準備幾個關鍵資訊，諮詢會準很多。",intro:"建議先整理孩子年級、目前程度、近期目標與可投入時間，再透過官方 Line 或表單聯繫。",nav:`<div class="page-nav"><a class="button button--primary" href="${SITE.lineUrl}" target="_blank" rel="noreferrer">官方 Line 客服</a><a class="button button--secondary" href="${SITE.fbUrl}" target="_blank" rel="noreferrer">前往 FB 社團</a></div>`,sections:[section("諮詢前建議整理","這能大幅提高顧問判斷的精準度。",`<div class="grid grid--3"><article class="card"><h3>孩子目前年級與體系</h3><p>公校、私校、雙語或國際體系，會影響準備策略。</p></article><article class="card"><h3>最近半年最重要的目標</h3><p>例如私中、資優鑑定、競賽或長線能力培養。</p></article><article class="card"><h3>目前遇到的卡點</h3><p>可能是觀念、速度、粗心、心態，或家長本身資訊過多難以判斷。</p></article></div>`)]})],"search.html":()=>["全站搜尋｜獵豹科教","全站搜尋",buildSearch()],"article.html":()=>["文章專欄｜獵豹科教","文章專欄",""],"mom-power.html":()=>{const a=MOMS.find((x)=>x.slug===PARAMS().get("slug"))||MOMS[0];return[`${a.title}｜星媽的正能量`,"星媽的正能量",momPage(a)];}};
  COURSES.forEach((c)=>{routes[c.file]=()=>[`${c.title}｜獵豹科教`,c.title,buildListPage("課程介紹",{title:c.title,intro:c.summary,nav:`<div class="page-nav"><a class="button button--primary" href="contact.html">預約課程諮詢</a><a class="back-link" href="courses.html">回課程總覽</a><a class="back-link" href="index.html">回首頁</a></div>`,sections:[section("課程重點","先看懂這門課真正解決什麼問題。",`<div class="grid grid--3">${c.bullets.map((b,i)=>`<article class="card"><h3>重點 ${i+1}</h3><p>${b}</p></article>`).join("")}</div>`),section("標籤","這門課的定位與對應需求。 ",`<div class="card">${tags(c.tags)}</div>`)]})];});
GOALS.forEach((g)=>{routes[g.file]=()=>[`${g.title}｜獵豹科教`,g.title,buildListPage("家長導航",{title:g.title,intro:g.intro,nav:`<div class="page-nav"><a class="button button--primary" href="${g.relatedCourse}">看建議課程</a><a class="back-link" href="needs.html">回家長導航</a><a class="back-link" href="index.html">回首頁</a></div>`,sections:[section("這個目標要先看懂的三件事","比起急著報班，先判斷孩子目前在哪裡更重要。",`<div class="grid grid--3">${g.points.map((p,i)=>`<article class="card"><h3>重點 ${i+1}</h3><p>${p}</p></article>`).join("")}</div>`),section("延伸閱讀","把家長最常一起關心的內容一起放進來。",`<div class="grid grid--2">${ARTICLES.slice(0,2).map((a)=>card(a,articleUrl(a.slug),"navy")).join("")}<article class="card"><h3>對應課程</h3><p>若你已大致確認目標與方向，可以先看對應課程，再決定是否需要諮詢。</p><a class="card-link" href="${g.relatedCourse}">前往課程頁</a></article></div>`)]})];});
  function wrapRichContentImages(){
    document.querySelectorAll(".article-body img, .elite-body img, .about-body img").forEach((img)=>{
      if(img.closest(".rich-shimmer-frame, .elite-card__cover, .about-overview__tile, .about-profile__media, .a_pic")) return;
      const frame=document.createElement("span");
      frame.className="rich-shimmer-frame";
      img.parentNode.insertBefore(frame,img);
      frame.appendChild(img);
    });
  }
  const picked=(routes[PAGE()]||routes["index.html"])();const main=document.querySelector("main.page");const shouldHydrateMain=!main||!main.children.length;applyChrome(picked[0],picked[1]);if(shouldHydrateMain)page(picked[2]);wrapRichContentImages();
  const targets=document.querySelectorAll(".hero-panel, .card, .feature-box, .section-heading, .goal-chip");targets.forEach((el)=>el.classList.add("reveal"));const observer=new IntersectionObserver((entries)=>entries.forEach((entry)=>entry.isIntersecting&&entry.target.classList.add("is-visible")),{threshold:.16});targets.forEach((el)=>observer.observe(el));
  const slider=document.querySelector("[data-banner-slider]");if(slider){const slides=[...slider.querySelectorAll(".hero-banner")],dots=[...slider.querySelectorAll("[data-banner-dot]")];let current=0;const show=(index)=>{slides.forEach((slide,i)=>slide.classList.toggle("is-active",i===index));dots.forEach((dot,i)=>dot.classList.toggle("is-active",i===index));current=index;};dots.forEach((dot)=>dot.addEventListener("click",()=>show(Number(dot.dataset.bannerDot))));setInterval(()=>show((current+1)%slides.length),4500);}
  const dataEl=document.getElementById("search-data");if(dataEl){const items=JSON.parse(dataEl.textContent),input=document.getElementById("site-search-input"),type=document.getElementById("filter-type"),grade=document.getElementById("filter-grade"),sort=document.getElementById("filter-sort"),box=document.getElementById("search-results");const score=(item,q)=>{if(!q)return item.popularity+item.freshness/10;const v=q.toLowerCase(),t=item.title.toLowerCase(),g=item.tags.join(" ").toLowerCase(),k=item.keywords.join(" ").toLowerCase(),s=item.summary.toLowerCase(),b=item.body.toLowerCase();let n=0;if(t===v)n+=100;if(t.includes(v))n+=70;if(g.includes(v))n+=50;if(k.includes(v))n+=45;if(s.includes(v))n+=30;if(b.includes(v))n+=15;return n+item.popularity/10+item.freshness/20;};const render=()=>{const q=input.value.trim();const list=items.filter((i)=>!type.value||i.type===type.value).filter((i)=>!grade.value||i.grade.includes(grade.value)).map((i)=>({...i,score:score(i,q)})).filter((i)=>!q||i.score>0).sort((a,b)=>sort.value==="latest"?b.freshness-a.freshness:sort.value==="popular"?b.popularity-a.popularity:b.score-a.score);box.innerHTML=list.length?list.map((i)=>`<article class="card search-card"><div class="search-card__head"><span class="search-result__type">${i.type}</span>${tags(i.tags.slice(0,3))}</div><h3>${i.title}</h3><p>${i.summary}</p><div class="card__meta-row"><span class="chip chip--muted">${i.grade}</span><span class="chip chip--muted">${i.topic}</span></div><a class="card-link" href="${i.url}">前往內容</a></article>`).join(""):`<div class="empty-state"><h3>沒有找到符合條件的結果</h3><p>可改試「私中」、「AMC」、「科學班」或「二階筆試」。</p></div>`;const url=new URL(location.href);q?url.searchParams.set("q",q):url.searchParams.delete("q");history.replaceState({}, "", url);};[input,type,grade,sort].forEach((el)=>el.addEventListener("input",render));render();}
})();
