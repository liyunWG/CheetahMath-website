  const card=(item,link,tone,pink)=>`<article class="card${pink?" card--mom":""}">${item.cover?cover(item.cover,tone):""}${meta(item.date,item.category,pink)}<h3>${item.title}</h3><p>${item.summary||item.text}</p>${tags(item.tags,pink)}${link?`<a class="card-link" href="${link}">閱讀更多</a>`:""}</article>`;
